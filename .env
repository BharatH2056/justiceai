# JusticeAI Environment Configuration
# Copy this file to .env.local and update with your values

# Server Configuration
PORT=3001
NODE_ENV=development

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
CHAT_MODEL=gemma3:4b

# Frontend Configuration
VITE_API_URL=http://localhost:3001
VITE_APP_NAME=JusticeAI
VITE_APP_VERSION=2.0.0

# Optional: Analytics (disabled by default for privacy)
VITE_ENABLE_ANALYTICS=false

# Optional: Feature Flags
VITE_ENABLE_STREAMING=true
VITE_ENABLE_OFFLINE_MODE=true

# Bhashini API Configuration (For Indian Language Voice Support)
# Get credentials from: https://bhashini.gov.in/
BHASHINI_API_KEY=your_bhashini_api_key_here
BHASHINI_USER_ID=your_bhashini_user_id_here
BHASHINI_PIPELINE_ID=64392f0502070e176378e90e

# Google Gemini Configuration (Fallback AI)
# Get your API key from: https://aistudio.google.com/
GEMINI_API_KEY=AIzaSyBlYdkJBOQ4IojQXt--c0ELRkxDeL4O3Wo
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek Cloud Configuration (Secondary Fallback)
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-6e666c025b3a4ba4af0e1d1cf5295828
DEEPSEEK_MODEL=deepseek-chat